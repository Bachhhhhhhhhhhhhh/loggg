{
  "name": "logiq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:stop": "powershell -NoProfile -Command \"Get-NetTCPConnection -LocalPort 3000 -EA SilentlyContinue | %% { taskkill /PID $_.OwningProcess /F 2>$null }\"",
    "build": "next build",
    "build:pages": "next build",
    "start": "next start -p 3000",
    "lint": "eslint",
    "setup": "npm install && npm run build"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "mammoth": "^1.12.0",
    "next": "16.2.10",
    "pdfjs-dist": "^6.1.200",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
